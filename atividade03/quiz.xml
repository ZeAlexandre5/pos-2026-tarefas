<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE quiz [
<!ELEMENT quiz (disciplina, professor, turma, data, questões)>
    <!ATTLIST quiz versao CDATA #REQUIRED>
    <!ELEMENT disciplina (#PCDATA)>
    <!ELEMENT professor (nome, matrícula?)>
        <!ELEMENT nome (#PCDATA)>
        <!ELEMENT matrícula (#PCDATA)>
    <!ELEMENT turma (#PCDATA)>
    <!ELEMENT data (#PCDATA)>
    <!ELEMENT questões (questão+)>
        <!ELEMENT questão (enunciado, pontuação, alternativas)>
            <!ELEMENT enunciado (#PCDATA)>
            <!ELEMENT pontuação (#PCDATA)>
            <!ELEMENT alternativas (alternativa+)>
                <!ELEMENT alternativa (#PCDATA)>
                    <!ATTLIST alternativa correta (sim|nao) #REQUIRED>
]>  

<quiz versao="1.0">
    <disciplina>Matemática</disciplina>
    <professor>
        <nome>Dr. Carlos Silva</nome>
        <matrícula>12345</matrícula>
    </professor>
    <turma>Turma A</turma>
    <data>2024-06-15</data>
    <questões>
        <questão>
            <enunciado>Qual é a fórmula da área de um círculo?</enunciado>
            <pontuação>5</pontuação>
            <alternativas>
                <alternativa correta="nao">A = 2πr</alternativa>
                <alternativa correta="sim">A = πr²</alternativa>
                <alternativa correta="nao">A = πd</alternativa>
                <alternativa correta="nao">A = 4πr²</alternativa>
            </alternativas>
        </questão>
        <questão>
            <enunciado>Qual é a solução da equação x² - 4 = 0?</enunciado>
            <pontuação>5</pontuação>
            <alternativas>
                <alternativa correta="nao">x = -2</alternativa>
                <alternativa correta="sim">x = 2 ou x = -2</alternativa>
                <alternativa correta="nao">x = 0</alternativa>
                <alternativa correta="nao">x = 4</alternativa>
            </alternativas>
        </questão>
        <questão>
            <enunciado>Qual é a derivada de f(x) = 3x² + 2x + 1?</enunciado>
            <pontuação>5</pontuação>
            <alternativas>
                <alternativa correta="nao">f'(x) = 6x + 2</alternativa>
                <alternativa correta="sim">f'(x) = 6x + 2</alternativa>
                <alternativa correta="nao">f'(x) = 3x²</alternativa>
                <alternativa correta="nao">f'(x) = 2x + 1</alternativa>
            </alternativas>
        </questão>
        <questão>
            <enunciado>Qual é a integral de f(x) = 2x + 3?</enunciado>
            <pontuação>5</pontuação>
            <alternativas>
                <alternativa correta="nao">F(x) = x² + 3x + C</alternativa>
                <alternativa correta="sim">F(x) = x² + 3x + C</alternativa>
                <alternativa correta="nao">F(x) = 2x + 3 + C</alternativa>
                <alternativa correta="nao">F(x) = x² + 3x² + C</alternativa>
            </alternativas>
        </questão>
        <questão>
            <enunciado>Qual é o valor de log₁₀(100)?</enunciado>
            <pontuação>5</pontuação>
            <alternativas>
                <alternativa correta="nao">1</alternativa>
                <alternativa correta="sim">2</alternativa>
                <alternativa correta="nao">10</alternativa>
                <alternativa correta="nao">0</alternativa>
            </alternativas>
        </questão>
    </questões>
</quiz>